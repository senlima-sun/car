{
  "name": "car-monorepo",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "packageManager": "pnpm@11.1.1",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "build:wasm": "cd physics-engine && wasm-pack build --target web --out-dir ../packages/physics/pkg",
    "build:wasm:release": "cd physics-engine && wasm-pack build --target web --out-dir ../packages/physics/pkg --release",
    "test": "turbo run test",
    "test:wasm": "cd physics-engine && cargo test",
    "check:wasm-clean": "cd physics-engine && cargo check --target wasm32-unknown-unknown --no-default-features",
    "test:scripts": "vitest run",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write .",
    "preview": "pnpm --filter @car/game preview",
    "compress:glb": "tsx --tsconfig scripts/tsconfig.json scripts/compress-glb.ts",
    "compress:textures": "tsx --tsconfig scripts/tsconfig.json scripts/compress-textures.ts",
    "upload:assets": "tsx --tsconfig scripts/tsconfig.json scripts/upload-assets.ts",
    "perf:smoke": "tsx --tsconfig scripts/tsconfig.json scripts/perf-smoke.ts",
    "check:turbo-cache": "tsx --tsconfig scripts/tsconfig.json scripts/check-turbo-cache.ts",
    "track:ingest": "tsx --tsconfig scripts/tsconfig.json scripts/convert-osm-track.ts",
    "track:validate-source": "tsx --tsconfig scripts/tsconfig.json scripts/validate-track-source.ts",
    "track:add": "tsx --tsconfig scripts/tsconfig.json scripts/track-add.ts",
    "track:elevation:fetch": "tsx --tsconfig scripts/tsconfig.json scripts/fetch-track-elevation.ts"
  },
  "devDependencies": {
    "dotenv": "^17.4.2",
    "geotiff": "^3.0.5",
    "prettier": "^3.7.4",
    "sharp": "^0.34.5",
    "tinyglobby": "^0.2.16",
    "tsx": "^4.22.3",
    "turbo": "^2.9.12",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  }
}
