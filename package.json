{
  "name": "car-racing-game",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun run build/dev.ts",
    "dev:server": "bun run build/dev-server.ts",
    "dev:wasm": "bun run build/watch-wasm.ts",

    "build": "bun run build:wasm && bun run build/build.ts",
    "preview": "bun run build/preview-server.ts",
    "format": "prettier --write .",
    "build:wasm": "cd physics-engine && wasm-pack build --target web --out-dir ../src/wasm/pkg",
    "build:wasm:release": "cd physics-engine && wasm-pack build --target web --out-dir ../src/wasm/pkg --release",
    "test:wasm": "cd physics-engine && cargo test",
    "test": "bun test"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.4.2",
    "@react-three/rapier": "^2.2.0",
    "posthog-js": "^1.306.1",

    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tailwindcss": "^4.1.18",
    "three": "^0.182.0",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@types/bun": "latest",

    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.182.0",
    "bun-plugin-tailwind": "^0.1.2",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3"
  }
}
