{
  "name": "car-monorepo",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "packageManager": "pnpm@11.1.1",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "build:wasm": "cd physics-engine && wasm-pack build --target web --out-dir ../apps/game/src/wasm/pkg",
    "build:wasm:release": "cd physics-engine && wasm-pack build --target web --out-dir ../apps/game/src/wasm/pkg --release",
    "test": "turbo run test",
    "test:wasm": "cd physics-engine && cargo test",
    "test:scripts": "bun test scripts/lib/",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write .",
    "preview": "pnpm --filter @car/game preview",
    "compress:glb": "pnpm --filter @car/game compress:glb",
    "perf:smoke": "bun run scripts/perf-smoke.ts",
    "track:ingest": "bun run scripts/convert-osm-track.ts",
    "track:validate-source": "bun run scripts/validate-track-source.ts",
    "track:add": "bun run scripts/track-add.ts"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.12"
  }
}
