{
  "$schema": "https://turborepo.com/schema.json",
  "extends": ["//"],
  "tasks": {
    "build": {
      "inputs": ["src/**", "wrangler.toml", "tsconfig.json", "package.json"],
      "outputs": ["dist/**"]
    },
    "test": {
      "inputs": ["src/**", "test/**", "tsconfig.json", "package.json"],
      "outputs": []
    },
    "typecheck": {
      "inputs": ["src/**", "test/**", "scripts/**", "tsconfig.json"],
      "outputs": []
    }
  }
}
