# Override the auth client's base URL if the API is cross-origin.
# Default (unset): `/api/auth`, served through the Vite dev proxy
# or the same origin in production.
# VITE_AUTH_BASE_URL=https://api.example.com/api/auth

# Override the static assets base URL (models, textures, ai-replays, demos).
# Default (unset): assets served from /public via Vite.
# Production: point at the R2 public URL.
# VITE_ASSETS_BASE_URL=https://pub-f1de381e33474a1a85e6ea033362de46.r2.dev
