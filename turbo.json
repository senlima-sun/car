{
  "$schema": "https://turborepo.com/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build", "build:wasm"],
      "outputs": []
    },
    "build:wasm": {
      "outputs": [],
      "inputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["build:wasm"],
      "outputs": []
    },
    "test:wasm": {
      "outputs": [],
      "inputs": []
    },
    "typecheck": {
      "dependsOn": ["^build", "build:wasm"],
      "outputs": []
    },
    "format": {
      "cache": false
    }
  }
}
