{
  "$schema": "https://turborepo.com/schema.json",
  "remoteCache": {
    "enabled": true,
    "apiUrl": "https://turbo-cache.solemnissn.workers.dev",
    "signature": true
  },
  "tasks": {
    "//#build:wasm": {
      "inputs": [
        "physics-engine/src/**",
        "physics-engine/Cargo.toml",
        "physics-engine/Cargo.lock"
      ],
      "outputs": ["apps/game/src/wasm/pkg/**"]
    },
    "build": {
      "dependsOn": ["//#build:wasm"],
      "inputs": [
        "src/**",
        "build/**",
        "public/**",
        "index.html",
        "bunfig.toml",
        "tsconfig.json",
        "package.json"
      ],
      "outputs": ["dist/**"]
    },
    "dev": {
      "dependsOn": ["//#build:wasm"],
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["//#build:wasm"],
      "inputs": ["src/**", "package.json", "tsconfig.json"],
      "outputs": []
    },
    "//#test:wasm": {
      "inputs": [
        "physics-engine/src/**",
        "physics-engine/tests/**",
        "physics-engine/Cargo.toml",
        "physics-engine/Cargo.lock"
      ],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["//#build:wasm"],
      "inputs": ["src/**", "tsconfig.json"],
      "outputs": []
    },
    "format": {
      "cache": false
    }
  }
}
